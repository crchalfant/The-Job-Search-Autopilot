# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# └ ─ Required ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Email (Gmail recommended — use an App Password, not your login password)
# To create an App Password: myaccount.google.com ℒ Security ℒ 2-Step Verification ℒ App passwords
EMAIL_FROM=you@gmail.com
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_TO=you@gmail.com

# Search APIs (all have free tiers)
BRAVE_API_KEY=BSA...
TAVILY_API_KEY=toly-...
ADZUNA_APP_ID=your-app-id
ADZUNA_APP_KEY=your-app-key

# └ ─ Optional ──────────────────────────────────────────────────
# USAJobs (free, register at developer.usajobs.gov)
USAJOBS_API_KEY=
USAJOBS_EMAIL=
